{
  "name": "pa-pedia-scripts",
  "version": "1.0.0",
  "description": "Build scripts for PA-Pedia faction data management",
  "type": "module",
  "scripts": {
    "test": "node --import tsx --test manifest-ordering.test.ts",
    "build:zips": "tsx build-faction-zips.ts",
    "upload:releases": "tsx upload-to-releases.ts",
    "generate:manifest": "tsx generate-manifest.ts",
    "release": "npm run build:zips && npm run upload:releases && npm run generate:manifest",
    "extract:base-data": "tsx extract-base-data.ts",
    "upload:base-data": "tsx upload-base-data.ts"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
